//ADDING TWO NUMBERS

#include <stdio.h>
int main()
{
int a,b,sum;
printf("enter the two numbers");
scanf("%d%d",&a,&b);
sum = a+b;
    printf("sum = %d",sum);
    return 0;
}

//SUBTRACTING TWO NUMBERS

#include <stdio.h>
void main()
{
    int a,b,sub;
    printf("enter the two numbers");
    scanf("%d%d",&a,&b);
    sub=a-b;
    printf("difference is %d",sub);
}

// division of two numbers

#include <stdio.h>
void main()
{
    int a,b,quationt,remainder;
    printf("enter the two numbers");
    scanf("%d%d",&a,&b);
    quationt = a/b;
    remainder = a%b;
    printf("quationt = %d\n",quationt);
    printf("remainder = %d",remainder);
}
